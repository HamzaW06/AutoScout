# Frontend runtime API base.
# For same-origin deployments, keep /api.
# For split deployments, set full API URL like https://api.example.com/api
VITE_API_BASE_URL=/api

# WebSocket base URL (without trailing slash).
# Example: wss://api.example.com
# Client appends /ws automatically unless already provided.
VITE_WS_BASE_URL=
